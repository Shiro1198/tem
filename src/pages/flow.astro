							<li class="mb-10 indent-2"><a href="#flow-3" class="heading-3 _page-link">3- xxx</a></li>
						</ul>
					</div>
					<div class="box-1">
						<p class="mb-20 font-m">テキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキストテキスト</p>
					</div>
					-->
				</div>
			</div>
		</div>
	</section>

</BaseLayout>
